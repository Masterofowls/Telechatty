# Client (Expo)
EXPO_PUBLIC_STREAM_API_KEY=your_stream_api_key
EXPO_PUBLIC_STREAM_APP_ID=your_stream_app_id
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# Use the publishable key (sb_publishable_...) or legacy anon JWT (eyJ...)
EXPO_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_your_key
EXPO_PUBLIC_API_URL=http://localhost:8081

# Server (Drizzle + API routes) — never commit real values
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
STREAM_API_SECRET=your_stream_api_secret

# Drizzle Studio (optional)
# DRIZZLE_STUDIO_HOST=127.0.0.1
# DRIZZLE_STUDIO_PORT=4983

# Optional — run npm run auth:disable-email (no confirmation emails on signup)
# Create at https://supabase.com/dashboard/account/tokens
# SUPABASE_ACCESS_TOKEN=sbp_...
