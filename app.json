{
  "expo": {
    "name": "Telechatty",
    "slug": "Telechatty",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "telechatty",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.telechatty.app"
    },
    "android": {
      "package": "com.telechatty.app",
      "adaptiveIcon": {
        "backgroundColor": "#3390EC"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#3390EC"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Telechatty to access your photos for chat attachments and avatars."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
